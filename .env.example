# Required: at least one of these must be set
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides
LLM_PROVIDER=anthropic          # anthropic | openai
WHISPER_MODEL=small             # tiny|base|small|medium|large
TTS_PROVIDER=edge               # edge | openai
TTS_VOICE=en-US-AriaNeural
MAX_VIDEO_SECONDS=5400          # 90 min
MAX_UPLOAD_MB=200
DATA_DIR=./data
HOST=127.0.0.1
PORT=8000
